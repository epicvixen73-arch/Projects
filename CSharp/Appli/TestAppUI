    // ========================================================================
    // MAIN WINDOW
    // ========================================================================
    public class MainWindow : Window
    {
        private readonly Grid _rootGrid;
        private readonly StackPanel _sidebar;
        private readonly ContentControl _contentArea;
        private readonly Control _historyPanel;
        private ListBox _historyListBox;
        private readonly ObservableCollection<CalculationHistory> _history;

        // Current module state
        private Control? _currentModule;

        public MainWindow()
        {
            InitializeTheme();
            _history = new ObservableCollection<CalculationHistory>();

            // Root layout: Sidebar | Content | History
            _rootGrid = new Grid
            {
                ColumnDefinitions = new ColumnDefinitions("240,*,300"),
                Background = new SolidColorBrush(Color.Parse("#f8f9fa"))
            };

            // ===== SIDEBAR =====
            _sidebar = CreateSidebar();
            Grid.SetColumn(_sidebar, 0);
            _rootGrid.Children.Add(_sidebar);

            // ===== CONTENT AREA =====
            _contentArea = new ContentControl
            {
                Background = new SolidColorBrush(Colors.White),
                Padding = new Thickness(40)
            };
            Grid.SetColumn(_contentArea, 1);
            _rootGrid.Children.Add(_contentArea);

            // ===== HISTORY PANEL (DOCKABLE) =====
            _historyPanel = CreateHistoryPanel();
            Grid.SetColumn(_historyPanel, 2);
            _rootGrid.Children.Add(_historyPanel);

            // Window config
            Title = "Test App — Calculatrice & Jeux";
            Width = 1400;
            Height = 800;
            WindowStartupLocation = WindowStartupLocation.CenterScreen;
            Content = _rootGrid;
        }

        private void InitializeTheme()
        {
            // Couleurs du design
            // Primary: #2563eb (bleu)
            // Secondary: #64748b (gris-bleu)
            // Success: #10b981 (vert)
            // Accent: #8b5cf6 (violet)
        }

        private StackPanel CreateSidebar()
        {
            var sidebar = new StackPanel
            {
                Background = new SolidColorBrush(Color.Parse("#1e293b")),
                Spacing = 0,
                Orientation = Orientation.Vertical
            };

            // Header
            var headerBorder = new Border
            {
                Background = new SolidColorBrush(Color.Parse("#0f172a")),
                Padding = new Thickness(20, 30, 20, 30),
                BorderThickness = new Thickness(0, 0, 0, 1),
                BorderBrush = new SolidColorBrush(Color.Parse("#334155"))
            };

            var headerText = new TextBlock
            {
                Text = "Test App",
                FontSize = 20,
                FontWeight = FontWeight.Bold,
                Foreground = new SolidColorBrush(Colors.White)
            };
            headerBorder.Child = headerText;
            sidebar.Children.Add(headerBorder);

            // Menu items
            var modules = new (string, Func<Control>)[] {
                ("📊 Calculatrice", CreateCalculatorModule),
                ("🎮 Juste Prix", CreateJustePrixModule),
                ("🌡️ Convertisseur", CreateConverterModule)
            };

            foreach (var (label, moduleFactory) in modules)
            {
                var btn = CreateSidebarButton(label, moduleFactory);
                sidebar.Children.Add(btn);
            }

            return sidebar;
        }

        private Button CreateSidebarButton(string label, Func<Control> moduleFactory)
        {
            var btn = new Button
            {
                Content = label,
                Background = new SolidColorBrush(Color.Parse("#1e293b")),
                Foreground = new SolidColorBrush(Color.Parse("#cbd5e1")),
                Padding = new Thickness(20, 16, 20, 16),
                BorderThickness = new Thickness(0),
                FontSize = 14,
                HorizontalAlignment = HorizontalAlignment.Stretch,
                HorizontalContentAlignment = HorizontalAlignment.Left,
                Cursor = new Cursor(StandardCursorType.Hand)
            };

            btn.AddHandler(PointerEnteredEvent, (s, e) =>
            {
                btn.Background = new SolidColorBrush(Color.Parse("#334155"));
                btn.Foreground = new SolidColorBrush(Colors.White);
            });

            btn.AddHandler(PointerExitedEvent, (s, e) =>
            {
                btn.Background = new SolidColorBrush(Color.Parse("#1e293b"));
                btn.Foreground = new SolidColorBrush(Color.Parse("#cbd5e1"));
            });

            btn.Click += (s, e) =>
            {
                _currentModule = moduleFactory();
                _contentArea.Content = _currentModule;
            };

            return btn;
        }

        private Border CreateHistoryPanel()
